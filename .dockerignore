# =============================================================================
# Docker ignore file for PolyBot
# =============================================================================
# Keep the image lean by excluding unnecessary files.
# This reduces build context size and speeds up builds.

# -----------------------------------------------------------------------------
# Version Control
# -----------------------------------------------------------------------------
.git/
.gitignore
.github/

# -----------------------------------------------------------------------------
# Python Cache & Virtual Environments
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
.eggs/
*.egg
*.egg-info/

# -----------------------------------------------------------------------------
# Build Artifacts
# -----------------------------------------------------------------------------
dist/
build/
*.whl

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-*

# -----------------------------------------------------------------------------
# Testing & Linting Cache
# -----------------------------------------------------------------------------
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# -----------------------------------------------------------------------------
# Environment & Secrets (NEVER include)
# -----------------------------------------------------------------------------
.env
.env.*
*.env
!env.example
secrets/
*.pem
*.key

# -----------------------------------------------------------------------------
# Runtime Data (generated at runtime)
# -----------------------------------------------------------------------------
*.db
*.db-journal
*.sqlite
*.sqlite3
bot_config.json
daily_pnl.json
positions.json
risk_state.json
trader_data_cache/
simulation_results/
audit_results/
exports/
data/
*.log
logs/

# -----------------------------------------------------------------------------
# Documentation (not needed at runtime)
# -----------------------------------------------------------------------------
docs/
*.md
!README.md

# -----------------------------------------------------------------------------
# Deployment Configs (not needed in image)
# -----------------------------------------------------------------------------
nixpacks.toml
.railway-rebuild
docker-compose*.yml
Makefile

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# Tests (optional - can include if you want to run tests in container)
# -----------------------------------------------------------------------------
tests/
conftest.py
