# ═══════════════════════════════════════════════════════════════════════════════
# POLYBOT CONFIGURATION (PATCH 2026)
# ═══════════════════════════════════════════════════════════════════════════════
# WICHTIG: Diese Datei enthält SICHERE TEST-DEFAULTS.
# Für Production-Trading: DRY_RUN=false und AUTO_EXECUTE=true setzen.
# Nach Deploy auf Railway tradet der Bot MIT ECHTEM GELD wenn so konfiguriert!
# ═══════════════════════════════════════════════════════════════════════════════

# ── CORE TRADING SETTINGS ──────────────────────────────────────────────────────
# SAFE DEFAULTS for testing - change for production!
REDEEM_ONLY=false              # true = kein Handel mehr, nur noch Redeem aktiver Positionen
MODE=updown                    # updown = 5min Up/Down Crypto Märkte (BTC/ETH/SOL)
DRY_RUN=true                   # SAFE DEFAULT: true = nur simulieren, false = ECHTE Trades!
AUTO_EXECUTE=false             # SAFE DEFAULT: false = keine Auto-Trades, true = automatisch traden

# ── PRODUCTION VALUES (uncomment for live trading) ─────────────────────────────
# DRY_RUN=false
# AUTO_EXECUTE=true

# ── EDGE & EV THRESHOLDS ───────────────────────────────────────────────────────
MIN_EV=0.015                   # Minimum Expected Value (0.015 = 1.5%)
MIN_EDGE_PERCENT=0.85          # Minimum Edge in Prozent

# ── POSITION SIZING (Kelly Criterion) ──────────────────────────────────────────
KELLY_MULTIPLIER=0.5           # 0.5 = Half-Kelly (sicherer), 1.0 = Full Kelly
MAX_POSITION_USD=50            # Maximale Position pro Trade in USD
MIN_TRADE_USD=5                # Minimale Trade-Größe in USD

# ── MARKET FILTERS ─────────────────────────────────────────────────────────────
MIN_LIQUIDITY_USD=200          # Minimum Liquidität in USD
MIN_VOLUME_USD=100             # Minimum 24h Volume in USD
UP_DOWN_ONLY=true              # true = nur 5min Up/Down Märkte
TARGET_SYMBOLS=BTC,ETH,SOL     # Welche Crypto-Symbole scannen

# ── LOGGING & DEBUGGING ────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG                # DEBUG für detaillierte Logs, INFO für weniger

# ── WALLET & CREDENTIALS (MUST SET ON RAILWAY!) ────────────────────────────────
# POLYGON_PRIVATE_KEY=0x...    # Dein Wallet Private Key (NIEMALS committen!)
# WALLET_ADDRESS=0x...         # Deine Wallet-Adresse
# ALCHEMY_API_KEY=...          # Alchemy API Key für schnelle RPCs

# ── HYPERPARAMETER OPTIMIZATION (optional) ─────────────────────────────────────
OPTUNA_SAMPLER=tpe             # tpe, cmaes, random, grid
OPTUNA_N_TRIALS=30
OPTUNA_VIZ_ENABLED=true
AUTO_APPLY_BEST=true
VIZ_DIR=/app/static/optuna_viz

# ── SCAN INTERVAL ──────────────────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=12       # Wie oft scannen (5-300s)

# ═══════════════════════════════════════════════════════════════════════════════
# V89: FULL REDEEMER - Independent On-Chain Position Redemption
# ═══════════════════════════════════════════════════════════════════════════════
# The Full Redeemer scans on-chain + Data API for ALL redeemable positions,
# independent of the bot's internal state. Works even after restart or state loss.
#
# Enable for production to ensure all winning positions are redeemed!

FULL_REDEEM_ENABLED=false      # true = enable full redeemer background task
FULL_REDEEM_INTERVAL_SECONDS=45  # How often to scan for redeemable positions

# Balance thresholds for redeem (MUCH lower than trading - only need gas)
MIN_REDEEM_BALANCE=0.08        # Min USDC for gas (trading needs $1.2+, redeem only gas)
REDEEM_GAS_BUFFER_PERCENT=30   # Gas price buffer percentage

# Manual trigger: POST /api/force_full_redeem
# Status check: GET /api/full_redeemer_status

# ═══════════════════════════════════════════════════════════════════════════════
# V92: PIGGYBANK – Optional profit savings (DISABLED by default)
# ═══════════════════════════════════════════════════════════════════════════════
# Set your OWN wallet + enable to auto-save a percentage of profits.
# No transfers happen unless ALL three are configured.

PIGGYBANK_ENABLED=false        # true = enable auto-savings
PIGGYBANK_WALLET=              # Your savings wallet address (e.g. 0xABC...)
PIGGYBANK_PCT=0.01             # Fraction of profit to save (0.01 = 1%)

# ═══════════════════════════════════════════════════════════════════════════════
# HYPERLIQUID ENGINE – Optional additional signal source
# ═══════════════════════════════════════════════════════════════════════════════
# Connects to Hyperliquid WebSocket for trade flow, OFI, and latency arb signals.
# Used automatically when HYPE 45 mode is selected in /modes dashboard.

HYPERLIQUID_ENABLED=false      # true = start Hyperliquid engine at boot

# ═══════════════════════════════════════════════════════════════════════════════
# V6: TIMING FILTER – Only trade in the optimal sweet spot window
# ═══════════════════════════════════════════════════════════════════════════════
# Strongest edge in 5-min markets appears in last 60-90 seconds.
# Trades outside this window are blocked unless edge exceeds the override.

TIMING_MIN_SECONDS_BEFORE_CLOSE=75   # Sweet spot starts at 75s before close
TIMING_MAX_SECONDS_BEFORE_CLOSE=20   # Don't trade below 20s (execution risk)
TIMING_STRONG_EDGE_OVERRIDE=0.045    # >4.5% edge can trade outside sweet spot

# ═══════════════════════════════════════════════════════════════════════════════
# V6: EDGE-BUCKETED KELLY – Adaptive position sizing by edge strength
# ═══════════════════════════════════════════════════════════════════════════════
# Conservative on weak edges, aggressive on strong edges.
# Replaces flat Half-Kelly when USE_BUCKETED_KELLY=true.

USE_BUCKETED_KELLY=true              # true = use bucketed sizing
KELLY_AVG_WIN_PCT=0.07               # Average win size (7%) — calibrate from real trades
KELLY_AVG_LOSS_PCT=0.04              # Average loss size (4%) — calibrate from real trades
